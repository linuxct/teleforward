<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      Optional & strictly opt-in: only requested when the user enables "Resolve saved contacts" for
      WhatsApp magic links (WhatsApp's `@lid` chats hide the phone number; the sender's saved-contact
      lookup uri is the only way back to a web.whatsapp.com/send link). Never requested automatically.
    -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!--
      Optional & strictly opt-in: only used when "Always listening" is enabled for remote actions,
      which runs a foreground service holding a long-poll to Telegram so button presses act
      immediately. Without it the app only polls in a short burst after each forward.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!--
      Lets the app notice it has been restarted. A foreground service does not survive a reboot, so
      without this "Always listening" could read as on while nothing had polled since the phone
      booted — every press in that window silently reaching nobody. Used only to restart that
      listener and to collect presses queued while the device was off.
    -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!--
      Package visibility (API 30+): allows PackageManager to enumerate other apps' launcher
      activities so AppCatalogRepository can list installed apps WITHOUT QUERY_ALL_PACKAGES.
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:name=".TeleForwardApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.TeleForward"
        android:usesCleartextTraffic="false"
        tools:targetApi="36">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.TeleForward">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.TeleNotificationListener"
            android:exported="false"
            android:label="@string/notification_listener_label"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!--
          Opt-in "always listening" poller for remote actions. Normally started from the settings
          toggle; START_STICKY brings it back after a process kill, and RemoteActionBootReceiver
          covers a reboot (which START_STICKY does not).
        -->
        <service
            android:name=".service.TelegramListenerService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!--
          Restarts the always-on listener after a reboot or an app update, and in either case queues a
          poll so presses made while the device was off are still collected and answered.
        -->
        <receiver
            android:name=".service.RemoteActionBootReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!--
          FileProvider for sharing the assembled diagnostics dump (app-private filesDir/diag) to the
          Android share sheet via a content:// URI with a per-consumer temporary read grant.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!--
          WorkManager is configured on-demand via TeleForwardApp : Configuration.Provider
          (Hilt-supplied HiltWorkerFactory), so the default startup initializer is removed.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
