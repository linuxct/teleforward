    <string name="channels_magic_link_title">Reconstruir enlace mágico</string>
    <string name="channels_magic_link_body">Aproximación: reconstruye el enlace al que apunta esta notificación a partir de los datos que expone y lo añade al mensaje reenviado. Es heurístico: no siempre encontrará una coincidencia.</string>

    <string name="channels_contacts_title">Resolver contactos guardados</string>
    <string name="channels_contacts_body">Esta app oculta los números de teléfono tras un ID interno, así que los chats con contactos guardados no se pueden enlazar sin acceso a Contactos. Concédelo para convertirlos en enlaces: el número no sale de tu móvil salvo dentro del enlace que reenvías.</string>
    <string name="channels_contacts_granted">Concedido</string>
    <string name="channels_contacts_grant">Conceder</string>

    <string name="channels_whole_app_title">Reenviar toda la app</string>
    <!-- %1$s es el nombre de la aplicación. -->
    <string name="channels_whole_app_body">Si está activado, se reenvía cada notificación de %1$s salvo que un canal de abajo lo anule.</string>
    <string name="channels_precedence_body">Prioridad: el interruptor de una conversación manda sobre el de su canal, y el de un canal manda sobre el ajuste de toda la app; activa o desactiva cualquiera de ellos para anularlo.</string>

    <string name="channels_empty_title">Aún no se ha visto ningún canal</string>
