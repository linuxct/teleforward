<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- No cleartext anywhere. TeleForward only ever talks to api.telegram.org over TLS. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
